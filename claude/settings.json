{
  "permissions": {
    "allow": [
      "mcp__plugin_atlassian_atlassian__atlassianUserInfo"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "REPO=\"$(dirname \"$(dirname \"$(readlink -f ~/.claude/settings.json)\")\")\"; cat \"$REPO/automation-backlog.md\" 2>/dev/null || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -d \"./docs/context\" ]; then FILES=$(find ./docs/context -name \"*.md\" 2>/dev/null | sort); if [ -n \"$FILES\" ]; then echo \"[HARNESS:context] Available project context:\"; echo \"$FILES\" | sed 's|^|  |'; else echo \"[HARNESS:context] docs/context/ exists but empty — use project-context skill to create\"; fi; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "S=$(jq -r '.tool_input.skill // empty' 2>/dev/null); [ -n \"$S\" ] && \"$HOME/.local/bin/harness-event\" emit skill-start --skill \"$S\" --runtime claude; true",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "backend-api-security@claude-code-workflows": true,
    "security-compliance@claude-code-workflows": true
  },
  "extraKnownMarketplaces": {
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    }
  },
  "effortLevel": "high",
  "theme": "light-daltonized"
}
